# SvelteKit (adapter-node). Proxies API calls to Flask (FLASK_API_URL).
FROM node:22-bookworm-slim AS builder

WORKDIR /web

COPY web/package.json web/package-lock.json ./
RUN npm ci

COPY web/ ./
ARG FLASK_API_URL=http://api:5051
ENV FLASK_API_URL=${FLASK_API_URL}

RUN npm run build && npm prune --omit=dev

FROM node:22-bookworm-slim

WORKDIR /web

# Tools routes (/api/tools/validate, feedback_report) run python3 against the mounted repo.
RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip \
    && pip3 install --no-cache-dir --break-system-packages python-dotenv \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /web/package.json ./
COPY --from=builder /web/build ./build
COPY --from=builder /web/node_modules ./node_modules

ENV NODE_ENV=production
ENV PORT=3000
ENV HOST=0.0.0.0

EXPOSE 3000

CMD ["node", "build/index.js"]
