# Flask API (Gunicorn). Use with docker-compose or run standalone.
FROM python:3.12-slim-bookworm

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app.py auth.py config.py db.py logger.py ./
COPY llm ./llm
COPY scripts ./scripts
COPY games ./games

ENV FLASK_HOST=0.0.0.0
ENV PYTHONUNBUFFERED=1

EXPOSE 5051

# SQLite: use a single worker to avoid concurrent writers on one DB file.
# Increase --timeout for slow LLM turns (Azure / large local models).
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -fsS http://127.0.0.1:5051/games >/dev/null || exit 1

CMD ["gunicorn", "--bind", "0.0.0.0:5051", "--workers", "1", "--threads", "4", "--timeout", "120", "app:app"]
