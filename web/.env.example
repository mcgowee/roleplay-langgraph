# Server-side only: where Flask `app.py` is listening (SvelteKit proxies to this).
FLASK_API_URL=http://127.0.0.1:5051

# Public URL of this site in production (SvelteKit / adapter-node). Example: https://rpg.example.com
# ORIGIN=https://rpg.example.com

# Absolute path to the roleplay-langgraph repo if `npm run dev` is run from `web/` only.
# Needed for /tools (validate, feedback_report, story_draft). Leave unset when cwd is repo root.
# RPG_REPO_ROOT=/home/you/projects/roleplay-langgraph
